# =====================================================================
# Pocket Agent — Environment Template
# Copy to .env and fill in values. .env is gitignored.
# =====================================================================

# Required. Anthropic API key with access to the Managed Agents beta.
# Get one at https://console.anthropic.com/. Without Managed Agents
# beta access, session.create will fail with permission_error.
ANTHROPIC_API_KEY=sk-ant-...

# After running `pnpm bootstrap-agent` once, fill these in. The script
# prints the IDs it created; copy them here so the server attaches all
# new sessions to the same managed agent. Leave the lines absent (or
# the values empty) on first run — bootstrap appends them.
# AGENT_ID=
# ENVIRONMENT_ID=

# Optional. Override the local API server port. Default 8787.
PORT=8787

# Optional. Override the SQLite file path. Default ./data/app.db.
DB_PATH=./data/app.db

# Optional. Override the file upload cache directory. Default ./data/uploads.
UPLOAD_CACHE_DIR=./data/uploads
